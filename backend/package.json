{
  "name": "backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:socket\"",
    "dev:server": "nodemon src/server.js",
    "dev:socket": "nodemon src/socket-server.js",
    "start": "node src/server.js",
    "start:socket": "node src/socket-server.js",
    "build": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "axios": "^1.8.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongoose": "^8.12.1",
    "serverless-http": "^3.2.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "nodemon": "^3.1.9"
  }
}
